{
  "policy": "family-bc-approved-lottie-assets",
  "purpose": "LottieFiles assets are approved accent motion for Family B/C reels, not hero metaphors or standalone proof.",
  "allowedRoles": [
    "accent",
    "transition",
    "CTA",
    "route-pulse",
    "highlight",
    "checkmark",
    "warning",
    "loader",
    "micro-icon",
    "proof-burst",
    "chart-accent",
    "payment-transfer",
    "data-transfer"
  ],
  "forbiddenRoles": [
    "unapproved-hero-metaphor",
    "decorative-clutter",
    "standalone-proof",
    "random-confetti",
    "unlicensed-asset"
  ],
  "requiredFieldsForNewAssets": [
    "id",
    "sourceUrl",
    "localPath",
    "licenseNote",
    "approvedUsage",
    "approvedByHuman",
    "fallbackNativeRemotionOption"
  ],
  "assets": [
    {
      "id": "phase3-approved-pulse",
      "sourceUrl": "https://lottiefiles.com/free-animations/chart",
      "localPath": "lottie/phase3-approved-pulse.json",
      "licenseNote": "Non-production local fixture used only to validate approved Lottie rendering.",
      "approvedUsage": "route-pulse",
      "approvedByHuman": true,
      "approvedBy": "phase-3-calibration",
      "fallbackNativeRemotionOption": "Use deterministic native LottieAccentLayer pulse if JSON fails QA.",
      "nonProduction": true
    }
  ]
}
